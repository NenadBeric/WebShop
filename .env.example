# Kopiraj u .env u korenu repozitorijuma (docker compose učitava .env automatski).
# Za `npm run dev` samo na mašini: možeš kopirati relevantne VITE_* i L10N_* u frontend/.env

# --- PostgreSQL (docker-compose servis `db`, port na hostu 5433) ---
POSTGRES_DB=webshop
POSTGRES_USER=webshop
POSTGRES_PASSWORD=webshop

# Za Alembic / backend VAN Docker-a (npr. `alembic upgrade head` iz foldera backend):
DATABASE_URL=postgresql+asyncpg://webshop:webshop@localhost:5433/webshop

JWT_SECRET=promeni-me-u-jak-klijuc

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development
ALLOW_LEGACY_AUTH=true
WEBSHOP_SEED_DEMO=true

# --- Zitadel / OIDC ---
# OIDC_ISSUER=https://...
# OIDC_ISSUER_EXTERNAL=
# OIDC_AUDIENCE=
# Primer OIDC_AUDIENCE: Client ID vašeg Zitadel API projekta (ili lista odvojena zarezom). Prazno = bez provere aud.

# --- Telegram (globalni fallback; bot token i chat ID mogu i u UI „Firma i pravila“ po tenantu) ---
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# --- SMTP (globalni fallback; tenant može prepisati u admin UI) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# --- AI / LLM (NL pretraga kataloga; isti obrasci kao Trainify) ---
# LLM_PROVIDER: openai | deepseek | openrouter | custom
LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODEL=          # opciono; podrazumevani model po provajderu (openai → gpt-4o-mini, itd.)
# LLM_BASE_URL=       # samo za LLM_PROVIDER=custom (OpenAI-kompatibilni endpoint, sa /v1)
# LLM_TEMPERATURE=0.7
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Frontend (Vite) — Zitadel SPA ---
# VITE_OIDC_AUTHORITY=https://...
# VITE_OIDC_CLIENT_ID=

# --- Frontend — centralni Lokalizacija servis ---
# VITE_L10N_BASE_URL=https://lokalizacija.example.com
# VITE_L10N_APP_KEY=
# Opciono: podskup grupa (zarezom), ako servis to podržava
# VITE_L10N_GROUPS=

# Cilj Vite dev proxyja za rutu /l10n (samo pri `npm run dev`, ne ide u browser bundle).
# Podrazumevano: http://localhost:4000
# L10N_PROXY_TARGET=http://localhost:4000
# U Docker frontend kontejneru, ako je L10n na host mašini (Windows/Mac):
# L10N_PROXY_TARGET=http://host.docker.internal:4000
